<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Friendship Collage" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Friendship Collage">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>


    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-stone-50 text-zinc-800 font-[Inter]">
    <header class="sticky top-0 z-30 border-b border-stone-200 bg-white/90 backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <%= link_to "Friendship Collage", (user_signed_in? ? my_collage_path : new_user_session_path), class: "font-[DM_Sans] text-xl font-bold text-teal-700" %>
        <% if user_signed_in? %>
          <div class="flex items-center gap-2 sm:gap-4">
            <%= link_to "My Collage", my_collage_path, class: "rounded-lg px-3 py-2 text-sm font-medium text-zinc-700 transition hover:bg-teal-50 hover:text-teal-700" %>
            <%= link_to "Tests", tests_path, class: "rounded-lg px-3 py-2 text-sm font-medium text-zinc-700 transition hover:bg-teal-50 hover:text-teal-700" %>
            <%= link_to "Friends", friends_path, class: "rounded-lg px-3 py-2 text-sm font-medium text-zinc-700 transition hover:bg-teal-50 hover:text-teal-700" %>
            <span class="hidden rounded-lg bg-stone-100 px-3 py-2 text-sm font-medium text-zinc-600 sm:inline"><%= current_user.username %></span>
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "rounded-lg bg-teal-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-teal-700" %>
          </div>
        <% end %>
      </nav>
    </header>

    <div class="mx-auto w-full max-w-6xl px-4 pt-6 sm:px-6 lg:px-8">
      <% if notice.present? %>
        <div class="mb-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800"><%= alert %></div>
      <% end %>
    </div>

    <main class="mx-auto w-full max-w-6xl px-4 pb-10 sm:px-6 lg:px-8">
      <%= yield %>
    </main>
  </body>
</html>
