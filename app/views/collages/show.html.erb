<section class="space-y-6">
  <header class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="font-[DM_Sans] text-3xl font-bold text-zinc-900">
        <%= @user == current_user ? "My Collage" : "#{@user.username}'s collage" %>
      </h1>
      <p class="mt-1 text-sm text-zinc-600">
        Track personality test results in one place.
      </p>
    </div>
    <div class="rounded-xl bg-teal-50 px-4 py-3 text-sm font-medium text-teal-800">
      <%= @result_map.size %> of <%= @supported_tests.size %> tests completed
    </div>
  </header>

  <div class="overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-stone-200">
      <thead class="bg-stone-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-500">Test</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-500">Result</th>
          <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-zinc-500">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-100">
        <% @supported_tests.each do |test| %>
          <% result = @result_map[test.id] %>
          <tr class="transition hover:bg-stone-50/80">
            <td class="px-4 py-4 text-sm font-medium text-zinc-900"><%= test.name %></td>
            <td class="px-4 py-4 text-sm">
              <% if result.present? %>
                <span class="rounded-full bg-teal-100 px-3 py-1 text-xs font-semibold text-teal-800"><%= result.result_value %></span>
              <% else %>
                <span class="text-zinc-500">Not taken</span>
              <% end %>
            </td>
            <td class="px-4 py-4 text-right">
              <% if @user == current_user %>
                <%= link_to "Update", test_path(test.slug), class: "rounded-lg border border-stone-300 px-3 py-2 text-xs font-semibold text-zinc-700 transition hover:border-teal-300 hover:text-teal-700" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
