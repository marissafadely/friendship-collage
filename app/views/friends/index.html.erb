<section class="space-y-6">
  <header>
    <h1 class="font-[DM_Sans] text-3xl font-bold text-zinc-900">Friends</h1>
    <p class="mt-1 text-sm text-zinc-600">Add friends by username and browse their collages.</p>
  </header>

  <section class="rounded-2xl border border-stone-200 bg-white p-6 shadow-sm">
    <%= form_with url: friends_path, method: :post, class: "flex flex-col gap-3 sm:flex-row" do |f| %>
      <%= f.text_field :username, placeholder: "Enter username", class: "w-full rounded-lg border border-stone-300 px-3 py-2 text-sm outline-none ring-teal-200 transition focus:border-teal-500 focus:ring-2", required: true %>
      <%= f.submit "Add friend", class: "rounded-lg bg-teal-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-teal-700" %>
    <% end %>
  </section>

  <% if @friendships.any? %>
    <ul class="space-y-3">
      <% @friendships.each do |friendship| %>
        <li class="flex flex-col gap-3 rounded-2xl border border-stone-200 bg-white p-4 shadow-sm sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-teal-100 text-sm font-bold text-teal-700">
              <%= friendship.friend.username.first.upcase %>
            </div>
            <div>
              <p class="text-sm font-semibold text-zinc-900"><%= friendship.friend.username %></p>
              <p class="text-xs text-zinc-500">Friend</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <%= link_to "View collage", user_collage_path(friendship.friend.username), class: "rounded-lg border border-stone-300 px-3 py-2 text-xs font-semibold text-zinc-700 transition hover:border-teal-300 hover:text-teal-700" %>
            <%= button_to "Remove", friend_path(friendship), method: :delete, class: "rounded-lg bg-rose-100 px-3 py-2 text-xs font-semibold text-rose-700 transition hover:bg-rose-200" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="rounded-2xl border border-dashed border-stone-300 bg-white p-8 text-center">
      <p class="font-[DM_Sans] text-xl font-semibold text-zinc-800">No friends yet</p>
      <p class="mt-1 text-sm text-zinc-500">Add a friend by username to start exploring collages.</p>
    </div>
  <% end %>
</section>
