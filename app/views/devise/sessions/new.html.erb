<section class="mx-auto mt-10 w-full max-w-md rounded-2xl border border-stone-200 bg-white p-6 shadow-sm">
  <h2 class="font-[DM_Sans] text-2xl font-bold text-zinc-900">Welcome back</h2>
  <p class="mt-1 text-sm text-zinc-600">Log in to view your collage and friends.</p>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
    <div>
      <%= f.label :email, class: "mb-1 block text-sm font-semibold text-zinc-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg border border-stone-300 px-3 py-2 text-sm outline-none ring-teal-200 transition focus:border-teal-500 focus:ring-2" %>
    </div>

    <div>
      <%= f.label :password, class: "mb-1 block text-sm font-semibold text-zinc-700" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-lg border border-stone-300 px-3 py-2 text-sm outline-none ring-teal-200 transition focus:border-teal-500 focus:ring-2" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2">
        <%= f.check_box :remember_me, class: "rounded border-stone-300 text-teal-600 focus:ring-teal-500" %>
        <%= f.label :remember_me, class: "text-sm text-zinc-600" %>
      </div>
    <% end %>

    <%= f.submit "Log in", class: "w-full rounded-lg bg-teal-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-teal-700" %>
  <% end %>

  <div class="mt-4 text-sm text-zinc-600">
    <%= render "devise/shared/links" %>
  </div>
</section>
