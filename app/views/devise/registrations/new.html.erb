<section class="mx-auto mt-10 w-full max-w-md rounded-2xl border border-stone-200 bg-white p-6 shadow-sm">
  <h2 class="font-[DM_Sans] text-2xl font-bold text-zinc-900">Create account</h2>
  <p class="mt-1 text-sm text-zinc-600">Start building your friendship collage.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :username, class: "mb-1 block text-sm font-semibold text-zinc-700" %>
      <%= f.text_field :username, autofocus: true, autocomplete: "username", class: "w-full rounded-lg border border-stone-300 px-3 py-2 text-sm outline-none ring-teal-200 transition focus:border-teal-500 focus:ring-2" %>
    </div>

    <div>
      <%= f.label :email, class: "mb-1 block text-sm font-semibold text-zinc-700" %>
      <%= f.email_field :email, autocomplete: "email", class: "w-full rounded-lg border border-stone-300 px-3 py-2 text-sm outline-none ring-teal-200 transition focus:border-teal-500 focus:ring-2" %>
    </div>

    <div>
      <%= f.label :password, class: "mb-1 block text-sm font-semibold text-zinc-700" %>
      <% if @minimum_password_length %>
        <p class="mb-1 text-xs text-zinc-500"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-lg border border-stone-300 px-3 py-2 text-sm outline-none ring-teal-200 transition focus:border-teal-500 focus:ring-2" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "mb-1 block text-sm font-semibold text-zinc-700" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-lg border border-stone-300 px-3 py-2 text-sm outline-none ring-teal-200 transition focus:border-teal-500 focus:ring-2" %>
    </div>

    <%= f.submit "Sign up", class: "w-full rounded-lg bg-teal-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-teal-700" %>
  <% end %>

  <div class="mt-4 text-sm text-zinc-600">
    <%= render "devise/shared/links" %>
  </div>
</section>
